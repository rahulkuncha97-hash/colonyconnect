{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "houseNumber": { "type": "string" },
        "floorNumber": { "type": "string" },
        "blockName": { "type": "string" },
        "wallpaperStyle": { "type": "string" },
        "customWallpaperUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Post": {
      "title": "Post",
      "description": "Community feed post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likesCount": { "type": "integer" }
      },
      "required": ["authorUid", "content", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Post comment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorUid", "content", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Group chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "content", "createdAt"]
    },
    "Location": {
      "title": "Location",
      "description": "Colony location marker",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["name", "lat", "lng"]
    },
    "Emergency": {
      "title": "Emergency",
      "description": "Emergency SOS alert",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "resolved"] },
        "location": { "type": "object" }
      },
      "required": ["uid", "userName", "userEmail", "timestamp", "status", "location"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Personal contact added by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phoneNumber"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/users/{uid}/contacts/{contactId}": { "schema": "Contact", "description": "User's personal contacts" },
    "/posts/{postId}": { "schema": "Post", "description": "Community posts" },
    "/posts/{postId}/comments/{commentId}": { "schema": "Comment", "description": "Post comments" },
    "/messages/{messageId}": { "schema": "Message", "description": "Group chat messages" },
    "/locations/{locationId}": { "schema": "Location", "description": "Colony locations" },
    "/emergencies/{emergencyId}": { "schema": "Emergency", "description": "Emergency alerts" }
  }
}
